# Server
APP_SERVER__HOST=0.0.0.0
APP_SERVER__PORT=8001
APP_SERVER__DEBUG=true
APP_SERVER__ENVIRONMENT=development

# Database
APP_DATABASE__URL=postgresql://user:password@localhost:5432/moneyrobert
APP_DATABASE__POOL_SIZE=5

# Redis
APP_REDIS__URL=redis://localhost:6379/0

# Security
APP_SECURITY__SECRET_KEY=your-secret-key-here-change-in-production
APP_SECURITY__ALGORITHM=HS256
APP_SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_SECURITY__REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
APP_CORS__ORIGINS=["http://localhost:3000", "http://localhost:5173"]
APP_CORS__ALLOW_CREDENTIALS=true

# Rate Limiting
APP_RATE_LIMIT__ENABLED=true
APP_RATE_LIMIT__REQUESTS_PER_MINUTE=100
APP_RATE_LIMIT__REQUESTS_PER_HOUR=1000

# WebSocket (OKX)
APP_WEBSOCKET__OKX_PUBLIC_URL=wss://ws.okx.com:8443/ws/v5/public
APP_WEBSOCKET__OKX_PRIVATE_URL=wss://ws.okx.com:8443/ws/v5/private
APP_WEBSOCKET__OKX_BUSINESS_URL=wss://ws.okx.com:8443/ws/v5/business

# News refresh (0 disables automatic refresh)
NEWS_FETCH_INTERVAL_MINUTES=15
